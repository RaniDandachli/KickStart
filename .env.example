# ---------------------------------------------------------------------------
# Expo app (bundled — only EXPO_PUBLIC_* is exposed to the client)
# Copy to `.env` and fill values from Supabase → Project Settings → API
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# `true` = sign-in required on cold start + full Supabase profile. `false` = skip straight to app (guest); use You tab → Sign in / Create account, or Welcome screen links.
EXPO_PUBLIC_ENABLE_BACKEND=false
# Optional: UUID of a second test user in Supabase Auth — used as the opponent when mock matchmaking finds the demo rival (mock_opponent_1) so 1v1 rows can be created in `match_sessions`.
# EXPO_PUBLIC_DEV_OPPONENT_USER_ID=

# Optional: Realtime-driven cache invalidation (`useRealtimeScaffold`)
EXPO_PUBLIC_ENABLE_REALTIME=false

# Stripe — publishable key only (test: pk_test_…, live: pk_live_…). Secret key must NEVER go here.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# When Checkout + Edge Functions + webhook are deployed, set true to enable Shop (wallet + credit packs).
EXPO_PUBLIC_WALLET_TOPUP_STRIPE_ENABLED=false

# Launch / compliance (client): counsel-approved pages and support — leave empty until hosted.
# EXPO_PUBLIC_TERMS_URL=https://example.com/terms
# EXPO_PUBLIC_PRIVACY_URL=https://example.com/privacy
# EXPO_PUBLIC_SUPPORT_CONTACT=support@example.com
# Comma-separated profile region codes that cannot enter paid skill contests (must match `profiles.region`).
# EXPO_PUBLIC_SKILL_CONTEST_BLOCKED_REGION_CODES=NY,NJ

# ---------------------------------------------------------------------------
# Supabase Edge Functions — set in Dashboard → Project Settings → Edge Functions → Secrets
# (or `npx supabase secrets set --env-file supabase/.env.functions` for CLI deploys)
# Never commit real secrets. Rotate when switching Stripe test → live.
# ---------------------------------------------------------------------------
# SUPABASE_URL=          # same as EXPO_PUBLIC_SUPABASE_URL (often auto-injected)
# SUPABASE_ANON_KEY=     # same as anon key (often auto-injected)
# SUPABASE_SERVICE_ROLE_KEY=  # service_role — server only
# STRIPE_SECRET_KEY=     # sk_test_… or sk_live_… — createWalletCheckoutSession, stripeWebhook, createStripeConnectLink
# STRIPE_WEBHOOK_SECRET= # whsec_… — Stripe Dashboard → Webhooks → endpoint signing secret
# Stripe Connect (Express payouts — prefilled in createStripeConnectLink; set to match your Stripe Connect settings)
# STRIPE_CONNECT_DEFAULT_COUNTRY=US
# STRIPE_CONNECT_BUSINESS_URL=https://runitarcade.app
# STRIPE_CONNECT_BUSINESS_NAME=RunitArcade
# STRIPE_CONNECT_MCC=7994
# STRIPE_CONNECT_PRODUCT_DESCRIPTION=Competitive gaming platform — tournaments and prizes
#
# redeem-gift-card Edge Function (gift codes never go to the client)
# RESEND_API_KEY=re_...
# After Resend shows your domain as verified, set sender on that domain (not onboarding@resend.dev):
# RESEND_FROM_EMAIL="Run It Arcade <rewards@yourdomain.com>"
# FROM_EMAIL=              # alias some setups use instead of RESEND_FROM_EMAIL
# SUPPORT_EMAIL=support@yourdomain.com
# BRAND_NAME=Run It Arcade
# EMAIL_LOGO_URL=https://YOUR_PROJECT.supabase.co/storage/v1/object/public/your-bucket/logo.png
#   Public https URL; PNG/JPG/WebP (SVG often blocked in clients). Bucket must be public — the Edge function
#   fetches and embeds the logo inline so Gmail shows it without remote image blocking.
#   Optional: set SUPPORT_EMAIL; if omitted, support@<your sending domain> is used (not example.com).
# EMAIL_SUBJECT_GIFT_CARD=Your Run It Arcade reward is here
#
# sendWelcomeEmail — Database Webhook on public.profiles INSERT (signup)
# WELCOME_EMAIL_WEBHOOK_SECRET=  # long random string; same value in Dashboard → Webhook → HTTP header Authorization: Bearer …
# EMAIL_SUBJECT_WELCOME=Welcome to Run It Arcade
#
# h2hMaintenance — scheduled stale lobby / queue cleanup (POST + header x-h2h-maintenance-secret)
# H2H_MAINTENANCE_SECRET=  # long random; add Supabase → Edge Functions → Cron calling this function every 15–60 min
