# Supabase (client — safe for EXPO_PUBLIC_* in bundles)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Optional: enable Realtime-driven cache invalidation in `useRealtimeScaffold`
EXPO_PUBLIC_ENABLE_REALTIME=false

# Stripe — publishable key only in the app (subscriptions / cosmetics checkout UI)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Edge Functions secrets (set in Supabase dashboard, never in the mobile app)
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=
