# Copy to `supabase/.env.functions` (gitignored) and fill in values.
# Push secrets to the hosted project:
#   npx supabase secrets set --env-file supabase/.env.functions
#
# Required for wallet top-ups, webhooks, and Connect (bank payouts):
STRIPE_SECRET_KEY=sk_test_...

# Optional — createStripeConnectLink uses these if set (see function source):
# Fallback only when profile has no shipping country and app sends no device region (rare):
# STRIPE_CONNECT_DEFAULT_COUNTRY=CA
# STRIPE_CONNECT_BUSINESS_URL=https://your-site.example
# STRIPE_CONNECT_BUSINESS_NAME=RunitArcade
# STRIPE_CONNECT_MCC=7994
# STRIPE_CONNECT_PRODUCT_DESCRIPTION=Mobile skill contests and tournament prizes
