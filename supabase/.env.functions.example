# Copy to `supabase/.env.functions` (gitignored) and fill in values.
# Push secrets to the hosted project:
#   npx supabase secrets set --env-file supabase/.env.functions
#
# Required for wallet top-ups, webhooks, and Connect (bank payouts):
STRIPE_SECRET_KEY=sk_test_...

# Optional — createStripeConnectLink uses these if set (see function source):
# Fallback only when profile has no shipping country and app sends no device region (rare):
# STRIPE_CONNECT_DEFAULT_COUNTRY=CA
# STRIPE_CONNECT_BUSINESS_URL=https://your-site.example
# STRIPE_CONNECT_BUSINESS_NAME=RunitArcade
# STRIPE_CONNECT_MCC=7994
# STRIPE_CONNECT_PRODUCT_DESCRIPTION=Mobile skill contests and tournament prizes

# Whop platforms — connected accounts + hosted payout portal (optional; alongside Stripe):
# WHOP_COMPANY_API_KEY=
# WHOP_PARENT_COMPANY_ID=biz_xxxxxxxxxxxxxx
#
# Whop checkout + webhooks (createWhopCheckoutSession, whopWebhook):
# WHOP_WEBHOOK_SECRET=   # signing secret from Whop Dashboard → Developer → Webhooks (Standard Webhooks)

# H2H maintenance + open-queue scan (h2hMaintenance, h2hOpenMatchWatchScan):
# H2H_MAINTENANCE_SECRET=

# Web Push (h2hOpenMatchWatchScan — browser notifications). Generate: npx web-push generate-vapid-keys
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# WEB_PUSH_CONTACT=mailto:support@yourdomain.com
# Optional — full URL opened when user taps the notification (default: WEB_PUSH_PUBLIC_ORIGIN + /play/live-matches):
# WEB_PUSH_PUBLIC_ORIGIN=https://your-production-site.com
# WEB_PUSH_OPEN_MATCH_PATH=/play/live-matches
