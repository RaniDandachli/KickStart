{
  "expo": {
    "name": "RunitArcade",
    "slug": "run-it",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/run-it-arcade-icon.png",
    "scheme": "runit",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/run-it-arcade-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/run-it-arcade-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/run-it-arcade-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow RunitArcade to set your profile photo from your library."
        }
      ],
      "expo-asset",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "",
          "enableGooglePay": true
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#ff006e"
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
